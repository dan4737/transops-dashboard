# Copy this file to .streamlit/secrets.toml (locally) or paste these keys into
# the Streamlit Community Cloud "Secrets" manager to enable email alerts.
# Leave it unset and the app still runs — the Alerts page just reports that
# email is not configured.

# Example using a Gmail App Password (recommended over your real password):
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "your.email@gmail.com"
SMTP_PASSWORD = "your-16-char-app-password"
ALERT_FROM = "your.email@gmail.com"
ALERT_TO = "ops-team@example.com"
